generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  displayName String
  domain      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trustCenterSettings TrustCenterSettings?
  trustCenterTheme    TrustCenterTheme?
  dataRoomSettings    DataRoomSettings?
  documents           TrustDocument[]
  accessRequests      AccessRequest[]
  approvedAccesses    ApprovedAccess[]
  suppliers           Supplier[]
  integrations        Integration[]
  activities          AuditActivity[]
}

model DataRoomSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  title          String
  subtitle       String
  note           String
  publishingMode String
  categoriesJson String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TrustCenterSettings {
  id                   String   @id @default(cuid())
  organizationId       String   @unique
  displayName          String
  publicDescription    String
  logoMode             String
  heroBadge            String
  heroUpdatedLabel     String
  heroTitle            String
  primaryCtaLabel      String
  secondaryCtaLabel    String
  securityContactEmail String
  responseSla          String
  draftSavedAt         DateTime?
  publishedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  heroSignals  TrustCenterHeroSignal[]
  sections     TrustCenterSection[]
  certifications TrustCenterCertification[]
  faqItems     TrustCenterFaqItem[]
}

model TrustCenterTheme {
  id             String   @id @default(cuid())
  organizationId String   @unique
  primary        String
  secondary      String
  button         String
  surface        String
  header         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TrustCenterHeroSignal {
  id         String @id
  settingsId String
  label      String
  value      String
  note       String
  position   Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustCenterSection {
  id         String @id
  settingsId String
  title      String
  description String
  enabled    Boolean
  position   Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustCenterCertification {
  id         String @id
  settingsId String
  label      String
  icon       String
  iconClass  String
  checked    Boolean
  position   Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustCenterFaqItem {
  id         String @id
  settingsId String
  question   String
  answer     String
  position   Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustDocument {
  id                   String   @id
  organizationId       String
  slug                 String   @unique
  name                 String
  description          String
  category             String
  visibility           String
  status               String
  version              String
  owner                String
  updatedAtLabel       String
  publishedAtLabel     String?
  sizeLabel            String
  downloads            Int      @default(0)
  icon                 String
  iconClass            String
  requiresApproval     Boolean
  approvalRule         String
  visibleInTrustCenter Boolean
  ndaRequired          Boolean
  tagsJson             String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accessRequests AccessRequest[]
  downloadEvents TrustDownloadEvent[]
}

model AccessRequest {
  id               String   @id
  organizationId   String
  documentId       String
  requester        String
  company          String
  email            String
  requestedAtLabel String
  reason           String
  status           String
  documentType     String?
  reviewTag        String?
  deniedAt         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document     TrustDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model ApprovedAccess {
  id             String   @id
  organizationId String
  requester      String
  email          String
  company        String
  document       String
  approvedAt     String
  expiresAt      String
  status         String
  statusClass    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TrustDownloadEvent {
  id          String @id
  documentId  String
  actor       String
  company     String
  actionLabel String
  timeLabel   String
  tone        String

  document TrustDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Supplier {
  id                       String   @id
  organizationId           String
  slug                     String   @unique
  legalName                String
  displayName              String
  domain                   String
  website                  String
  supplierType             String
  segment                  String
  subsegment               String
  headquartersCity         String
  headquartersCountry      String
  taxId                    String
  primaryContactName       String
  primaryContactRole       String
  primaryContactEmail      String
  securityContactEmail     String
  privacyContactEmail      String
  businessOwner            String
  criticality              String
  integrationType          String
  dataClassification       String
  accessScope              String
  hostingModel             String
  activeRegions            String
  servicesProvided         String
  countriesOfOperation     String
  notes                    String
  risk                     String
  lifecycleStatus          String
  status                   String
  score                    Int?
  previousScore            Int?
  trend                    Int?
  createdAtLabel           String
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model QuestionnaireTemplate {
  id          String   @id
  name        String
  category    String
  version     String
  source      String
  criticality String?
  objective   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Integration {
  id             String   @id
  organizationId String
  slug           String   @unique
  listName       String
  title          String
  subtitle       String
  status         String
  statusClass    String
  owner          String
  category       String
  syncWindow     String
  notesJson      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditActivity {
  id             String   @id @default(cuid())
  organizationId String
  type           String
  title          String
  description    String
  actor          String?
  entityType     String?
  entityId       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
