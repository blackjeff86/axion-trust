generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserType {
  internal
  external
}

enum OrganizationRole {
  owner
  admin
  editor
  viewer
}

enum MembershipStatus {
  invited
  active
  suspended
}

enum AccessRequestStatus {
  pending
  approved
  denied
  cancelled
}

enum DocumentAccessGrantStatus {
  active
  expired
  revoked
}

enum TrustDownloadAction {
  download
  preview
  request_access
  nda_accept
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  displayName String
  domain      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trustCenterSettings  TrustCenterSettings?
  trustCenterTheme     TrustCenterTheme?
  dataRoomSettings     DataRoomSettings?
  documents            TrustDocument[]
  accessRequests       AccessRequest[]
  documentAccessGrants DocumentAccessGrant[]
  members              OrganizationMember[]
  suppliers            Supplier[]
  integrations         Integration[]
  activities           AuditActivity[]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  company         String?
  title           String?
  userType        UserType  @default(external)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships        OrganizationMember[]
  invitedMemberships OrganizationMember[]  @relation("MembershipInviter")
  accessRequests     AccessRequest[]       @relation("AccessRequester")
  documentGrants     DocumentAccessGrant[]
  downloadEvents     TrustDownloadEvent[]
  auditActivities    AuditActivity[]       @relation("AuditActor")
}

model OrganizationMember {
  id              String           @id @default(cuid())
  organizationId  String
  userId          String
  role            OrganizationRole
  status          MembershipStatus @default(active)
  title           String?
  invitedByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser    User?                 @relation("MembershipInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  reviewedRequests AccessRequest[]       @relation("AccessRequestReviewer")
  grantedAccesses  DocumentAccessGrant[] @relation("GrantApprover")
  auditActivities  AuditActivity[]       @relation("AuditActorMember")

  @@unique([organizationId, userId])
}

model DataRoomSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  title          String
  subtitle       String
  note           String
  publishingMode String
  categoriesJson String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TrustCenterSettings {
  id                   String    @id @default(cuid())
  organizationId       String    @unique
  displayName          String
  publicDescription    String
  logoMode             String
  heroBadge            String
  heroUpdatedLabel     String
  heroTitle            String
  primaryCtaLabel      String
  secondaryCtaLabel    String
  securityContactEmail String
  responseSla          String
  draftSavedAt         DateTime?
  publishedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  heroSignals    TrustCenterHeroSignal[]
  sections       TrustCenterSection[]
  certifications TrustCenterCertification[]
  faqItems       TrustCenterFaqItem[]
}

model TrustCenterTheme {
  id             String   @id @default(cuid())
  organizationId String   @unique
  primary        String
  secondary      String
  button         String
  surface        String
  header         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TrustCenterHeroSignal {
  id         String @id
  settingsId String
  label      String
  value      String
  note       String
  position   Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustCenterSection {
  id          String  @id
  settingsId  String
  title       String
  description String
  enabled     Boolean
  position    Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustCenterCertification {
  id         String  @id
  settingsId String
  label      String
  icon       String
  iconClass  String
  checked    Boolean
  position   Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustCenterFaqItem {
  id         String @id
  settingsId String
  question   String
  answer     String
  position   Int

  settings TrustCenterSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model TrustDocument {
  id                   String   @id
  organizationId       String
  slug                 String
  name                 String
  description          String
  category             String
  visibility           String
  status               String
  version              String
  owner                String
  updatedAtLabel       String
  publishedAtLabel     String?
  sizeLabel            String
  downloads            Int      @default(0)
  icon                 String
  iconClass            String
  requiresApproval     Boolean
  approvalRule         String
  visibleInTrustCenter Boolean
  ndaRequired          Boolean
  tagsJson             String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accessRequests AccessRequest[]
  accessGrants   DocumentAccessGrant[]
  downloadEvents TrustDownloadEvent[]

  @@unique([organizationId, slug])
}

model AccessRequest {
  id                 String              @id @default(cuid())
  organizationId     String
  documentId         String
  requesterUserId    String?
  requesterName      String
  requesterEmail     String
  requesterCompany   String
  reason             String
  status             AccessRequestStatus @default(pending)
  requestedAt        DateTime            @default(now())
  reviewedAt         DateTime?
  reviewedByMemberId String?
  ndaAcceptedAt      DateTime?
  documentType       String?
  reviewTag          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document         TrustDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  requesterUser    User?                 @relation("AccessRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  reviewedByMember OrganizationMember?   @relation("AccessRequestReviewer", fields: [reviewedByMemberId], references: [id], onDelete: SetNull)
  documentGrants   DocumentAccessGrant[]
}

model DocumentAccessGrant {
  id                String                    @id @default(cuid())
  organizationId    String
  documentId        String
  userId            String
  grantedByMemberId String?
  sourceRequestId   String?
  expiresAt         DateTime
  revokedAt         DateTime?
  ndaAcceptedAt     DateTime?
  status            DocumentAccessGrantStatus @default(active)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document        TrustDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedByMember OrganizationMember?  @relation("GrantApprover", fields: [grantedByMemberId], references: [id], onDelete: SetNull)
  sourceRequest   AccessRequest?       @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)
  downloadEvents  TrustDownloadEvent[]

  @@unique([organizationId, documentId, userId])
}

model TrustDownloadEvent {
  id                String              @id @default(cuid())
  documentId        String
  userId            String?
  actorNameSnapshot String?
  emailSnapshot     String?
  companySnapshot   String?
  accessGrantId     String?
  action            TrustDownloadAction
  createdAt         DateTime            @default(now())

  document    TrustDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  accessGrant DocumentAccessGrant? @relation(fields: [accessGrantId], references: [id], onDelete: SetNull)
}

model Supplier {
  id                   String   @id
  organizationId       String
  slug                 String   @unique
  legalName            String
  displayName          String
  domain               String
  website              String
  supplierType         String
  segment              String
  subsegment           String
  headquartersCity     String
  headquartersCountry  String
  taxId                String
  primaryContactName   String
  primaryContactRole   String
  primaryContactEmail  String
  securityContactEmail String
  privacyContactEmail  String
  businessOwner        String
  criticality          String
  integrationType      String
  dataClassification   String
  accessScope          String
  hostingModel         String
  activeRegions        String
  servicesProvided     String
  countriesOfOperation String
  notes                String
  risk                 String
  lifecycleStatus      String
  status               String
  score                Int?
  previousScore        Int?
  trend                Int?
  createdAtLabel       String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model QuestionnaireTemplate {
  id          String   @id
  name        String
  category    String
  version     String
  source      String
  criticality String?
  objective   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Integration {
  id             String   @id
  organizationId String
  slug           String   @unique
  listName       String
  title          String
  subtitle       String
  status         String
  statusClass    String
  owner          String
  category       String
  syncWindow     String
  notesJson      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditActivity {
  id             String   @id @default(cuid())
  organizationId String
  type           String
  title          String
  description    String
  actor          String?
  actorUserId    String?
  actorMemberId  String?
  entityType     String?
  entityId       String?
  createdAt      DateTime @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User?               @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMember  OrganizationMember? @relation("AuditActorMember", fields: [actorMemberId], references: [id], onDelete: SetNull)
}
